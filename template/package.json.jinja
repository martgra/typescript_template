{
  "name": "{{ project_name }}",
  "version": "1.0.0",
  "description": "{{ project_description }}",
  "type": "module",
  "private": true,{% if author_name %}
  "author": "{{ author_name }}{% if author_email %} <{{ author_email }}>{% endif %}",{% endif %}
  "engines": {
    "bun": ">=1.3.1"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write . && prettier --write \"**/*.{md,yml,yaml}\"",
    "format:check": "biome format . && prettier --check \"**/*.{md,yml,yaml}\"",
    "check": "biome check --write . && prettier --write \"**/*.{md,yml,yaml}\"",
    "secretlint": "secretlint",
    "knip": "knip",
    "knip:production": "knip --production",
    "prepare": "husky"
  },
  "lint-staged": {
    "*": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ],
    "*.{md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/node": "^24.9.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "@secretlint/secretlint-rule-preset-recommend": "^11.2.5",
    "secretlint": "^11.2.5",
    "knip": "^5.33.3",
    "prettier": "^3.0.0",
    "typescript": "^5.2.2"
  }
}
