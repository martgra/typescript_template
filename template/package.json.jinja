{
  "name": "{{ project_name }}",
  "version": "1.0.0",
  "description": "{{ project_description }}",
  "private": true,{% if author_name %}
  "author": "{{ author_name }}{% if author_email %} <{{ author_email }}>{% endif %}",{% endif %}
  "scripts": {
    "build": "tsc",
    "dev": "{{ package_manager }} run --watch src/index.ts",
    "start": "{{ package_manager }} run src/index.ts",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "knip": "knip",
    "knip:production": "knip --production"{% if setup_husky %},
    "prepare": "husky install"{% endif %}
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.5.1",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.0",{% if setup_husky %}
    "husky": "^8.0.3",
    "lint-staged": "^15.2.10",{% endif %}
    "knip": "^5.33.3",
    "prettier": "^3.0.0",
    "typescript": "^5.2.2"
  }
}
